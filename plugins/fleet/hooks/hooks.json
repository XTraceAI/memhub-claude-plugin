{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/fleet_board.py\" session-start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/fleet_board.py\" prompt"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 15,
            "command": "IN=$(cat); case \"$IN\" in *git*commit*) printf %s \"$IN\" | python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/fleet_board.py\" post-tool ;; esac"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/fleet_board.py\" session-end"
          }
        ]
      }
    ]
  }
}
